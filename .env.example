# Nuxt automatically maps NUXT_PUBLIC_* vars to runtimeConfig.public.*
# NUXT_PUBLIC_SANITY_PROJECT_ID  →  runtimeConfig.public.sanityProjectId
# NUXT_PUBLIC_SANITY_DATASET     →  runtimeConfig.public.sanityDataset
# NUXT_PUBLIC_SANITY_API_VERSION →  runtimeConfig.public.sanityApiVersion

NUXT_PUBLIC_SANITY_PROJECT_ID=
NUXT_PUBLIC_SANITY_DATASET=production
NUXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ── Seed script only ─────────────────────────────────
# Editor token — NEVER commit. Only used by scripts/seed-sanity.ts.
# Create at: https://sanity.io/manage → project → API → Tokens
SANITY_API_TOKEN=
